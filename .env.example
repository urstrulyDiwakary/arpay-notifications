# =============================================================================
# ARPAY Notifications - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_VERSION=latest
APP_PORT=8086
SPRING_PROFILES_ACTIVE=production

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# CRITICAL: Change default credentials in production!
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ARPAY
DB_USERNAME=arpay_notifications
# SECURITY: Generate a strong password (min 32 chars recommended)
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Redis Configuration
# CRITICAL: Set a strong password in production
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# SECURITY: Generate a strong password
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# JWT Security Configuration
# CRITICAL: MUST be changed in production!
# Generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
# SECURITY: Use a 64+ character random string
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM_STRING_HERE_JWT_SECRET_KEY_FOR_PRODUCTION
JWT_EXPIRATION_MS=172800000

# -----------------------------------------------------------------------------
# Internal API Authentication (Service-to-Service)
# CRITICAL: MUST be changed in production!
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
# SECURITY: Use a strong API key (64+ chars recommended)
INTERNAL_API_KEYS=CHANGE_ME_USE_STRONG_API_KEY_HERE_FOR_INTERNAL_SERVICES

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging Configuration
# -----------------------------------------------------------------------------
FIREBASE_ENABLED=true
# Path to Firebase service account JSON key file
FIREBASE_KEY_PATH=./firebase

# -----------------------------------------------------------------------------
# Email/SMTP Configuration
# For Gmail: Use App Password, not regular password
# Generate App Password: https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# SECURITY: Use App Password for Gmail
MAIL_PASSWORD=your-app-password-here

# -----------------------------------------------------------------------------
# CORS Configuration
# SECURITY: Only add your actual production domains
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://arpay.anantarealty.in,https://api.arpay.anantarealty.in

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# Adjust based on your expected traffic
# -----------------------------------------------------------------------------
NOTIFICATIONS_RATELIMIT_ENABLED=true
NOTIFICATIONS_RATELIMIT_GLOBAL_PERMITS_PER_SECOND=1000
NOTIFICATIONS_RATELIMIT_PER_ENDPOINT_PERMITS_PER_SECOND=100
NOTIFICATIONS_RATELIMIT_PER_CLIENT_PERMITS_PER_SECOND=10

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ARPAY=INFO

# -----------------------------------------------------------------------------
# SSL Configuration (if not using reverse proxy)
# -----------------------------------------------------------------------------
SERVER_SSL_ENABLED=false
# SERVER_SSL_KEY_STORE=classpath:certs/keystore.p12
# SERVER_SSL_KEY_STORE_PASSWORD=changeit
# SERVER_SSL_KEY_ALIAS=arpay-notifications

# -----------------------------------------------------------------------------
# Arpay Backend URL (for inter-service communication)
# -----------------------------------------------------------------------------
ARPAY_BACKEND_URL=https://api.arpay.anantarealty.in

# -----------------------------------------------------------------------------
# Alerting Configuration (Optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Nginx Configuration (Optional - for standalone deployments)
# -----------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# -----------------------------------------------------------------------------
# Monitoring Stack (Optional)
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# SECURITY: Change default Grafana password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Resource Limits (Optional - adjust based on your VPS capacity)
# -----------------------------------------------------------------------------
# APP_CPU_LIMIT=2.0
# APP_MEMORY_LIMIT=2G
# POSTGRES_CPU_LIMIT=1.0
# POSTGRES_MEMORY_LIMIT=1G
# REDIS_CPU_LIMIT=0.5
# REDIS_MEMORY_LIMIT=512M
